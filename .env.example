# ─── Network ───────────────────────────────────────────────────────
# "testnet" or "mainnet"
NETWORK=testnet

# ─── Stellar Deployer ──────────────────────────────────────────────
# Secret key of the deployer account that funds new wallets
STELLAR_DEPLOYER_SECRET=S_your_stellar_deployer_secret_here

# ─── Soroban Contract ──────────────────────────────────────────────
STELLAR_CONTRACT_ID_TESTNET=CC6PXQKS7WIPCM22O6COEIKDO5AY75S62OVJQ4IMJ34RBBIOKCFS3C3I
STELLAR_CONTRACT_ID_MAINNET=

# ─── API Secret ────────────────────────────────────────────────────
# Random secret — only the Orbi app knows this
ORBI_API_SECRET=your_random_secret_here

# ─── Supabase ──────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

